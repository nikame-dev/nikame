# NIKAME — Environment Variables
# Copy to .env and fill in values

# Application environment (local/staging/production)
APP_ENV=

# Application name
APP_NAME=

# CORS allowed origins (comma-separated)
CORS_ORIGINS=

# Grafana admin password (auto-generated)
GRAFANA_ADMIN_PASSWORD=

# Keycloak admin username
KEYCLOAK_ADMIN=

# Keycloak admin password (auto-generated)
KEYCLOAK_ADMIN_PASSWORD=

# PostgreSQL database name
POSTGRES_DB=

# PostgreSQL password (auto-generated)
POSTGRES_PASSWORD=

# PostgreSQL username
POSTGRES_USER=
