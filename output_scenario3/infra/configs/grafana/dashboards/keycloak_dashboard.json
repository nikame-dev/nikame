{
  "title": "test-full-saas \u2014 Keycloak",
  "uid": "nikame-keycloak",
  "panels": [
    {
      "title": "Login Success Rate",
      "type": "stat",
      "targets": [
        {
          "expr": "rate(keycloak_login_total[5m])"
        }
      ]
    },
    {
      "title": "Login Failures",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(keycloak_login_error_total[5m])"
        }
      ]
    },
    {
      "title": "Active Sessions",
      "type": "gauge",
      "targets": [
        {
          "expr": "keycloak_sessions_count"
        }
      ]
    },
    {
      "title": "JVM Memory",
      "type": "timeseries",
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{job='keycloak'}"
        }
      ]
    }
  ]
}