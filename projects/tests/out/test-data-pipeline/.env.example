# NIKAME — Environment Variables
# Copy to .env and fill in values

# Application environment (local/staging/production)
APP_ENV=

# Application name
APP_NAME=

# CORS allowed origins (comma-separated)
CORS_ORIGINS=

# Grafana admin password (auto-generated)
GRAFANA_ADMIN_PASSWORD=

# JWT signing secret (auto-generated)
JWT_SECRET_KEY=

# MinIO root password (auto-generated)
MINIO_ROOT_PASSWORD=

# MinIO root username
MINIO_ROOT_USER=

# PostgreSQL database name
POSTGRES_DB=

# PostgreSQL password (auto-generated)
POSTGRES_PASSWORD=

# PostgreSQL username
POSTGRES_USER=

# Application-wide signing secret (auto-generated)
SECRET_KEY=

# Auto-added by rules engine
AWS_SECRET_ACCESS_KEY=
# Auto-added by rules engine
MLFLOW_S3_ENDPOINT_URL=
# Auto-added by rules engine
EVIDENTLY_HOST=
# Auto-added by rules engine
AWS_ACCESS_KEY_ID=
# Auto-added by rules engine
DATABASE_URL=
# Auto-added by rules engine
TEST_DATABASE_URL=
# Auto-added by rules engine
DB_POOL_SIZE=
# Auto-added by rules engine
MAX_RETRY_ATTEMPTS=