# Base
APP_ENV=development
DEBUG=True

# Secrets
SECRET_KEY=change_me_in_prod

# Database
DB_URL=postgresql+asyncpg://user:pass@localhost:5432/dbname

# Redis
REDIS_URL=redis://localhost:6379/0

# Hugging Face
HF_TOKEN=                          # For gated models
HF_HOME=~/.cache/huggingface       # Cache directory
HF_MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.2

# Model loading
MODEL_DEVICE=auto                  # auto | cuda | cpu | mps
MODEL_DTYPE=auto                   # auto | float16 | bfloat16 | float32
MODEL_LOAD_IN_8BIT=false
MODEL_LOAD_IN_4BIT=false
MODEL_MAX_MEMORY=                  # JSON: {"0": "20GB", "1": "20GB"}

# Local models
MODELS_DIR=~/.fastcheat/models     # Where local GGUF/ONNX files live
GGUF_MODEL_FILE=mistral-7b.Q4_K_M.gguf
GGUF_N_GPU_LAYERS=-1
GGUF_N_CTX=4096

# External model servers
TGI_BASE_URL=http://localhost:8080
VLLM_BASE_URL=http://localhost:8000
OLLAMA_BASE_URL=http://localhost:11434

# Inference
LLM_PROVIDER=openai               # openai | anthropic | ollama | vllm | gguf | hf-pipeline
MAX_CONCURRENT_INFERENCE=4        # GPU semaphore limit
INFERENCE_TIMEOUT_SECONDS=30
MODEL_WARMUP_RUNS=2
